# Ignore Terraform folders
TerraformApplication/
Terraform Resources/

# Terraform directories and state
TerraformApplication/.aws
TerraformApplication/.terraform
TerraformApplication/terraform.tfstate
TerraformApplication/terraform.tfstate.backup
TerraformApplication/.terraform.lock.hcl

Terraform Resources/.aws

# Python caches
__pycache__/
**/__pycache__/
*.py[cod]

# VSCode
.vscode/

# Flask logs and caches
FlaskApplication/__pycache__/
FlaskApplication/logs/
FlaskApplication/**/*.ipynb


# Env files (credentials only, not entire src/)

.env
.env.*
FlaskApplication/src/.env
FlaskApplication/src/.env.*

# Virtual Environments added afterwards
env_3.8/
**/env_3.8/

# Hidden Terraform Directories added afterwards (terraform.tfstate, terraform.tfstate.backup ignored as well)
.terraform/
**/.terraform/
secrets.*
terraform.*
